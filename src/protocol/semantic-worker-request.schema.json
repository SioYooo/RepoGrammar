{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repogrammar.local/schemas/semantic-worker-request.schema.json",
  "title": "RepoGrammar semantic worker request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "request_id",
    "project_root",
    "changed_files"
  ],
  "properties": {
    "protocol_version": {
      "type": "integer",
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "project_root": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:/|[A-Za-z]:[\\\\/]).+",
      "description": "Absolute canonical project root supplied by the Rust adapter."
    },
    "changed_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*\\\\)(?!.*://).+$"
      }
    }
  }
}
