{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repogrammar.local/schemas/semantic-worker-message.schema.json",
  "title": "RepoGrammar semantic worker NDJSON message",
  "oneOf": [
    { "$ref": "#/$defs/fact_message" },
    { "$ref": "#/$defs/progress_message" },
    { "$ref": "#/$defs/worker_error_message" },
    { "$ref": "#/$defs/end_of_stream_message" }
  ],
  "$defs": {
    "protocol_version": {
      "type": "integer",
      "const": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "fact_kind": {
      "type": "string",
      "enum": [
        "RESOLVED_CALL",
        "RESOLVED_IMPORT",
        "SYMBOL",
        "TYPE",
        "FRAMEWORK_ROLE",
        "UNKNOWN"
      ]
    },
    "certainty": {
      "type": "string",
      "enum": [
        "SEMANTIC",
        "DATAFLOW_DERIVED",
        "STRUCTURAL",
        "FRAMEWORK_HEURISTIC",
        "CONFLICTING",
        "UNKNOWN"
      ]
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "engine_version", "method"],
      "properties": {
        "engine": { "type": "string", "minLength": 1 },
        "engine_version": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code_unit_id",
        "path",
        "content_hash",
        "repository_revision",
        "start_byte",
        "end_byte",
        "note"
      ],
      "properties": {
        "code_unit_id": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*\\\\)(?!.*://).+$"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        },
        "repository_revision": { "type": "string", "minLength": 1 },
        "start_byte": { "type": "integer", "minimum": 0 },
        "end_byte": { "type": "integer", "minimum": 0 },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "work": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "const": "unknown" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "completed", "total"],
          "properties": {
            "kind": { "type": "string", "const": "known" },
            "completed": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "fact_message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "message_type",
        "request_id",
        "fact_kind",
        "subject",
        "origin",
        "certainty",
        "evidence",
        "assumptions"
      ],
      "properties": {
        "protocol_version": { "$ref": "#/$defs/protocol_version" },
        "message_type": { "type": "string", "const": "fact" },
        "request_id": { "$ref": "#/$defs/request_id" },
        "fact_kind": { "$ref": "#/$defs/fact_kind" },
        "subject": { "type": "string", "minLength": 1 },
        "target": {
          "anyOf": [
            { "type": "string", "minLength": 1, "pattern": "\\S" },
            { "type": "null" }
          ]
        },
        "origin": { "$ref": "#/$defs/origin" },
        "certainty": { "$ref": "#/$defs/certainty" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "progress_message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "message_type",
        "request_id",
        "stage",
        "message",
        "work"
      ],
      "properties": {
        "protocol_version": { "$ref": "#/$defs/protocol_version" },
        "message_type": { "type": "string", "const": "progress" },
        "request_id": { "$ref": "#/$defs/request_id" },
        "stage": {
          "type": "string",
          "enum": [
            "project_discovery",
            "file_scanning",
            "syntax_parsing",
            "semantic_resolution",
            "code_unit_extraction_normalization",
            "candidate_discovery",
            "family_construction",
            "persistence_validation"
          ]
        },
        "message": { "type": "string", "minLength": 1 },
        "work": { "$ref": "#/$defs/work" }
      }
    },
    "worker_error_message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "message_type",
        "request_id",
        "error_code",
        "message"
      ],
      "properties": {
        "protocol_version": { "$ref": "#/$defs/protocol_version" },
        "message_type": { "type": "string", "const": "worker_error" },
        "request_id": { "$ref": "#/$defs/request_id" },
        "error_code": {
          "type": "string",
          "enum": [
            "SEMANTIC_WORKER_UNAVAILABLE",
            "SEMANTIC_VERSION_UNSUPPORTED",
            "SEMANTIC_PROTOCOL_VIOLATION"
          ]
        },
        "message": { "type": "string", "minLength": 1 },
        "fallback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "certainty"],
          "properties": {
            "mode": { "type": "string", "const": "syntax_only" },
            "certainty": {
              "type": "string",
              "enum": ["STRUCTURAL", "UNKNOWN"]
            }
          }
        }
      }
    },
    "end_of_stream_message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "message_type", "request_id"],
      "properties": {
        "protocol_version": { "$ref": "#/$defs/protocol_version" },
        "message_type": { "type": "string", "const": "end_of_stream" },
        "request_id": { "$ref": "#/$defs/request_id" }
      }
    }
  }
}
